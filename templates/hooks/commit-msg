#!/usr/bin/env bash
# nyann hook v1 — commit-msg
# Enforces Conventional Commits:
#   <type>[optional scope][!]: <description>
# type ∈ feat|fix|chore|docs|refactor|test|perf|ci|build|style|revert
set -e

msg_file="$1"
[[ -f "$msg_file" ]] || exit 0

first_line="$(head -n 1 "$msg_file")"

# Permit merge / revert / squash commits where the subject is autogenerated.
case "$first_line" in
  "Merge "*|"Revert "*|"fixup! "*|"squash! "*|"amend! "*) exit 0 ;;
esac

regex='^(feat|fix|chore|docs|refactor|test|perf|ci|build|style|revert)(\([^)]+\))?!?: .+'

if ! [[ "$first_line" =~ $regex ]]; then
  printf '\n[nyann] commit message does not match Conventional Commits format.\n' >&2
  printf '  expected: <type>[(scope)][!]: <description>\n' >&2
  printf '  types:    feat | fix | chore | docs | refactor | test | perf | ci | build | style | revert\n' >&2
  printf '  got:      %s\n\n' "$first_line" >&2
  printf '  examples:\n' >&2
  printf '    feat: add login page\n' >&2
  printf '    fix(api): treat 204 as success\n' >&2
  printf '    feat!: drop support for node 16\n\n' >&2
  exit 1
fi

# macOS / Linux noise
.DS_Store
*.swp
*~
*.bak
*.orig
*.rej

# Editor / IDE
.idea/
.vscode/

# Per-user local state (Claude Code agent memory, third-party plugin caches)
.claude/
.claude-octopus/

# Runtime caches
profiles/_validated_at_version
profiles/_validated/

# Design proposals and roadmap brainstorms — drafts stay local.
# Distilled outcomes land in CHANGELOG and the principles docs.
# Force-add (`git add -f`) if a file ever genuinely belongs in the tree.
docs/proposals/
docs/roadmap/

# Orphan-detector scratch state (written by find-orphans.sh)
.orphaned_at

# Language / tooling artifacts (in case contributors run tests against fixtures)
node_modules/
__pycache__/
*.pyc
.pytest_cache/
.coverage
htmlcov/
dist/
build/
*.log


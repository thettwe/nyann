# macOS / Linux noise
.DS_Store
*.swp
*~
*.bak
*.orig
*.rej

# Editor / IDE
.idea/
.vscode/

# Per-user local state (Claude Code agent memory, third-party plugin caches)
.claude/
.claude-octopus/

# Runtime caches
profiles/_validated_at_version
profiles/_validated/

# Design proposals — drafts stay local. Proposals are working
# documents for the maintainer and don't ship in the repo. Their
# distilled outcomes land in CHANGELOG and the principles docs
# instead. Force-add (`git add -f`) is required if a proposal
# ever genuinely belongs in the tree.
docs/proposals/

# Language / tooling artifacts (in case contributors run tests against fixtures)
node_modules/
__pycache__/
*.pyc
.pytest_cache/
.coverage
htmlcov/
dist/
build/
*.log


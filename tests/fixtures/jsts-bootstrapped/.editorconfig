# nyann-managed — .editorconfig
# Shared editor baseline. Remove this file to opt out of nyann's default.
root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{md,markdown}]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

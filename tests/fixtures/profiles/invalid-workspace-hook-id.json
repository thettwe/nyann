{
  "$schema": "https://nyann.dev/schemas/profile/v1.json",
  "name": "invalid-workspace-hook-id",
  "description": "Workspace overrides with a hook id containing path-traversal — must fail.",
  "schemaVersion": 1,
  "stack": {
    "primary_language": "typescript"
  },
  "branching": {
    "strategy": "github-flow",
    "base_branches": ["main"]
  },
  "hooks": {
    "pre_commit": [],
    "commit_msg": [],
    "pre_push": []
  },
  "extras": {},
  "conventions": {
    "commit_format": "conventional-commits"
  },
  "workspaces": {
    "apps/web": {
      "hooks": {
        "pre_commit": ["../../../etc/passwd"]
      }
    }
  },
  "documentation": {
    "scaffold_types": [],
    "storage_strategy": "local",
    "claude_md_mode": "router"
  }
}

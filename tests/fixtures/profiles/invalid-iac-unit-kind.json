{
  "$schema": "https://nyann.dev/schemas/profile/v1.json",
  "name": "invalid-iac-unit-kind",
  "description": "v1.13.0 negative control: a units[].kind outside the enum must be rejected. Guards the nested unit-kind enum against a future relaxation.",
  "schemaVersion": 1,
  "archetype": "infra",
  "stack": {
    "primary_language": "hcl",
    "framework": "terraform",
    "package_manager": "opentofu"
  },
  "branching": {
    "strategy": "trunk-based",
    "base_branches": ["main"]
  },
  "hooks": {
    "pre_commit": ["block-main"],
    "commit_msg": ["conventional-commits"],
    "pre_push": []
  },
  "iac": {
    "tool": "terraform",
    "units": [
      { "kind": "widget", "path": "modules/vpc", "name": "vpc" }
    ]
  }
}

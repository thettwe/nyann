{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nyann.dev/schemas/docs-staleness/v1.json",
  "title": "DocsStalenessReport",
  "description": "Output of bin/docs-staleness.sh — doc files whose correlated sources have changed substantially since the doc was last touched.",
  "type": "object",
  "additionalProperties": false,
  "required": ["target", "thresholds", "summary", "findings"],
  "properties": {
    "target": { "type": "string" },
    "scanned_at": { "type": "string", "format": "date-time" },
    "thresholds": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commits", "days"],
      "properties": {
        "commits": { "type": "integer", "minimum": 1 },
        "days":    { "type": "integer", "minimum": 1 }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stale_count", "checked_count"],
      "properties": {
        "stale_count":   { "type": "integer", "minimum": 0 },
        "checked_count": { "type": "integer", "minimum": 0 }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["doc", "last_doc_change_days", "source_changes_since"],
        "properties": {
          "doc":                       { "type": "string" },
          "last_doc_change_days":      { "type": "integer", "minimum": 0 },
          "source_changes_since":      { "type": "integer", "minimum": 0, "description": "Number of commits on correlated sources since the doc was last touched." },
          "correlated_sources_sample": { "type": "array", "items": { "type": "string" } },
          "reason":                    { "type": "string" }
        }
      }
    }
  }
}

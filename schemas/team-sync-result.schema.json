{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nyann.dev/schemas/team-sync-result/v1.json",
  "title": "TeamSyncResult",
  "description": "Output of bin/sync-team-profiles.sh — per-team-source clone/fetch result + the profiles that registered cleanly. Consumed by skills/sync-team-profiles/SKILL.md.",
  "type": "object",
  "additionalProperties": false,
  "required": ["synced", "skipped", "registered", "invalid"],
  "properties": {
    "synced": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "synced_at"],
        "properties": {
          "name": { "type": "string" },
          "synced_at": { "type": "integer", "description": "Unix timestamp." }
        }
      }
    },
    "skipped": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "reason"],
        "properties": {
          "name": { "type": "string" },
          "reason": { "type": "string", "enum": ["within-interval"] },
          "next_due": { "type": "integer" }
        }
      }
    },
    "registered": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source", "name", "namespaced", "path"],
        "properties": {
          "source": { "type": "string" },
          "name": { "type": "string" },
          "namespaced": { "type": "string" },
          "path": { "type": "string" }
        }
      }
    },
    "invalid": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "kind"],
        "properties": {
          "name": { "type": "string" },
          "source": { "type": "string" },
          "path": { "type": "string" },
          "kind": {
            "type": "string",
            "enum": ["invalid-name", "invalid-ref", "invalid-url", "fetch-failed", "clone-failed", "toctou", "invalid-schema"]
          },
          "error": { "type": "string" }
        }
      }
    },
    "updates_available": {
      "type": "array",
      "description": "Present only on the --check-updates path: one changelog entry per pinned source that is behind its latest available ref. Each item mirrors the team-profile-changelog element shape (kept inline rather than $ref'd so validation stays offline — the $id base would otherwise resolve the relative ref to a network URL).",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source_name", "pinned_at", "latest", "commits_behind", "changed_profiles", "commit_log"],
        "properties": {
          "source_name":     { "type": "string" },
          "pinned_at":       { "type": "string", "description": "Current pinned ref (SHA or tag)." },
          "latest":          { "type": "string", "description": "Latest available ref on the remote." },
          "commits_behind":  { "type": "integer", "minimum": 0 },
          "changed_profiles": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Profile filenames that changed between pinned and latest."
          },
          "commit_log": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "sha":     { "type": "string" },
                "subject": { "type": "string" }
              }
            },
            "description": "Commits between pinned and latest (newest first)."
          }
        }
      }
    }
  }
}

{
  "$schema": "https://nyann.dev/schemas/profile/v1.json",
  "name": "terraform-monorepo",
  "description": "Terraform monorepo (modules/* + environments/*): fmt, validate, tflint, tfsec, terraform-docs. Trunk-based.",
  "schemaVersion": 1,
  "archetype": "infra",
  "stack": {
    "primary_language": "hcl",
    "framework": "terraform",
    "package_manager": null
  },
  "branching": {
    "strategy": "trunk-based",
    "base_branches": ["main"],
    "branch_name_patterns": {
      "feature": "feat/{slug}",
      "bugfix": "fix/{slug}"
    }
  },
  "hooks": {
    "pre_commit": [
      "terraform-fmt",
      "terraform-validate",
      "tflint",
      "tfsec",
      "terraform-docs",
      "block-main",
      "gitleaks"
    ],
    "commit_msg": [
      "conventional-commits"
    ],
    "pre_push": []
  },
  "extras": {
    "gitignore": true,
    "editorconfig": true,
    "claude_md": true,
    "github_actions_ci": true,
    "commit_message_template": true,
    "github_templates": true
  },
  "conventions": {
    "commit_format": "conventional-commits",
    "commit_scopes": [
      "modules",
      "environments",
      "ci",
      "docs"
    ]
  },
  "documentation": {
    "use_archetype_scaffolds": true,
    "scaffold_types": [
      "architecture",
      "runbook",
      "deployment",
      "adrs",
      "glossary"
    ],
    "storage_strategy": "local",
    "preferred_mcp": null,
    "adr_format": "madr",
    "claude_md_mode": "router",
    "claude_md_size_budget_kb": 3,
    "staleness_days": null,
    "enable_drift_checks": {
      "broken_internal_links": true,
      "broken_mcp_links": true,
      "orphans": true,
      "staleness": true
    },
    "glossary": {
      "auto_populate": false
    }
  },
  "ci": {
    "enabled": true
  }
}

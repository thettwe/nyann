{
  "$schema": "https://nyann.dev/schemas/profile/v1.json",
  "name": "deno-app",
  "description": "Deno application (deno.json / deno.jsonc): built-in `deno fmt` + `deno lint`, no separate prettier/eslint chain. Suits libraries, CLIs, and HTTP services running on the Deno runtime.",
  "schemaVersion": 1,
  "stack": {
    "primary_language": "typescript",
    "framework": "deno",
    "package_manager": "deno"
  },
  "branching": {
    "strategy": "github-flow",
    "base_branches": ["main"],
    "branch_name_patterns": {
      "feature": "feat/{slug}",
      "bugfix": "fix/{slug}"
    }
  },
  "hooks": {
    "pre_commit": [
      "deno-fmt-lint",
      "block-main",
      "gitleaks"
    ],
    "commit_msg": [
      "conventional-commits"
    ],
    "pre_push": []
  },
  "extras": {
    "gitignore": true,
    "editorconfig": true,
    "claude_md": true,
    "github_actions_ci": false,
    "commit_message_template": true,
    "github_templates": true
  },
  "conventions": {
    "commit_format": "conventional-commits",
    "commit_scopes": [
      "api",
      "deps",
      "tests",
      "docs",
      "build"
    ]
  },
  "documentation": {
    "scaffold_types": [
      "architecture",
      "adrs",
      "research"
    ],
    "storage_strategy": "local",
    "preferred_mcp": null,
    "adr_format": "madr",
    "claude_md_mode": "router",
    "claude_md_size_budget_kb": 3,
    "staleness_days": null,
    "enable_drift_checks": {
      "broken_internal_links": true,
      "broken_mcp_links": true,
      "orphans": true,
      "staleness": false
    }
  },
  "ci": {
    "enabled": true
  }
}

{
  "$schema": "https://nyann.dev/schemas/profile/v1.json",
  "name": "phoenix-app",
  "description": "Elixir Phoenix application (`mix.exs` + `:phoenix` dep): `mix format` for formatting, `mix credo` for static analysis, ExUnit for tests. Mix is the package manager; runs on Erlang/OTP.",
  "schemaVersion": 1,
  "stack": {
    "primary_language": "elixir",
    "framework": "phoenix",
    "package_manager": "mix"
  },
  "branching": {
    "strategy": "github-flow",
    "base_branches": ["main"],
    "branch_name_patterns": {
      "feature": "feat/{slug}",
      "bugfix": "fix/{slug}"
    }
  },
  "hooks": {
    "pre_commit": [
      "mix-format",
      "mix-credo",
      "block-main",
      "gitleaks"
    ],
    "commit_msg": [
      "conventional-commits"
    ],
    "pre_push": [
      "mix-test"
    ]
  },
  "extras": {
    "gitignore": true,
    "editorconfig": true,
    "claude_md": true,
    "github_actions_ci": false,
    "commit_message_template": true,
    "github_templates": true
  },
  "conventions": {
    "commit_format": "conventional-commits",
    "commit_scopes": [
      "live",
      "controllers",
      "channels",
      "schemas",
      "ecto",
      "ctx",
      "tests",
      "docs"
    ]
  },
  "documentation": {
    "scaffold_types": [
      "architecture",
      "prd",
      "adrs",
      "research"
    ],
    "storage_strategy": "local",
    "preferred_mcp": null,
    "adr_format": "madr",
    "claude_md_mode": "router",
    "claude_md_size_budget_kb": 3,
    "staleness_days": null,
    "enable_drift_checks": {
      "broken_internal_links": true,
      "broken_mcp_links": true,
      "orphans": true,
      "staleness": false
    }
  },
  "ci": {
    "enabled": true
  }
}

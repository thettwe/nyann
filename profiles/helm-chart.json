{
  "$schema": "https://nyann.dev/schemas/profile/v1.json",
  "name": "helm-chart",
  "description": "Helm chart (Chart.yaml + templates/ + values.yaml): helm lint + helm template render-check. Subcharts under charts/* are chart units. Trunk-based.",
  "schemaVersion": 1,
  "archetype": "infra",
  "stack": {
    "primary_language": "yaml",
    "framework": "helm",
    "package_manager": null
  },
  "branching": {
    "strategy": "trunk-based",
    "base_branches": ["main"],
    "branch_name_patterns": {
      "feature": "feat/{slug}",
      "bugfix": "fix/{slug}"
    }
  },
  "hooks": {
    "pre_commit": [
      "helm-lint",
      "helm-template-check",
      "block-main",
      "gitleaks"
    ],
    "commit_msg": [
      "conventional-commits"
    ],
    "pre_push": []
  },
  "extras": {
    "gitignore": true,
    "editorconfig": true,
    "claude_md": true,
    "github_actions_ci": true,
    "commit_message_template": true,
    "github_templates": true
  },
  "conventions": {
    "commit_format": "conventional-commits",
    "commit_scopes": [
      "chart",
      "templates",
      "values",
      "ci",
      "docs"
    ]
  },
  "guards": {
    "commit": [
      { "name": "wip-commits", "severity": "confirm" }
    ]
  },
  "iac": {
    "tool": "helm",
    "units": [
      { "kind": "chart", "path": "charts/app", "name": "app" }
    ]
  },
  "documentation": {
    "use_archetype_scaffolds": true,
    "scaffold_types": [
      "architecture",
      "runbook",
      "deployment",
      "adrs",
      "glossary"
    ],
    "storage_strategy": "local",
    "preferred_mcp": null,
    "adr_format": "madr",
    "claude_md_mode": "router",
    "claude_md_size_budget_kb": 3,
    "staleness_days": null,
    "staleness_threshold_commits": 5,
    "staleness_threshold_days": 30,
    "drift_check": {
      "enabled": true,
      "scanned_files": ["README.md"],
      "version_refs": { "enabled": true },
      "file_refs": { "enabled": true },
      "script_refs": { "enabled": true }
    },
    "readme_badges": {
      "enabled": true,
      "license": true,
      "ci": true,
      "release": true
    },
    "readme_stack_icons": {
      "enabled": true
    },
    "enable_drift_checks": {
      "broken_internal_links": true,
      "broken_mcp_links": true,
      "orphans": true,
      "staleness": true
    },
    "glossary": {
      "auto_populate": false
    }
  },
  "ci": {
    "enabled": true
  }
}

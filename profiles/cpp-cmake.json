{
  "$schema": "https://nyann.dev/schemas/profile/v1.json",
  "name": "cpp-cmake",
  "description": "C / C++ project with CMake build (`CMakeLists.txt` at root): clang-format for formatting, clang-tidy for static analysis. Package manager intentionally null — vcpkg / conan / system apt are all valid and out of nyann's wedge.",
  "schemaVersion": 1,
  "stack": {
    "primary_language": "cpp",
    "framework": "cmake",
    "package_manager": null
  },
  "branching": {
    "strategy": "github-flow",
    "base_branches": ["main"],
    "branch_name_patterns": {
      "feature": "feat/{slug}",
      "bugfix": "fix/{slug}"
    }
  },
  "hooks": {
    "pre_commit": [
      "clang-format",
      "block-main",
      "gitleaks"
    ],
    "commit_msg": [
      "conventional-commits"
    ],
    "pre_push": []
  },
  "extras": {
    "gitignore": true,
    "editorconfig": true,
    "claude_md": true,
    "github_actions_ci": false,
    "commit_message_template": true,
    "github_templates": true
  },
  "conventions": {
    "commit_format": "conventional-commits",
    "commit_scopes": [
      "core",
      "build",
      "tests",
      "docs",
      "deps",
      "ci"
    ]
  },
  "documentation": {
    "scaffold_types": [
      "architecture",
      "adrs",
      "research"
    ],
    "storage_strategy": "local",
    "preferred_mcp": null,
    "adr_format": "madr",
    "claude_md_mode": "router",
    "claude_md_size_budget_kb": 3,
    "staleness_days": null,
    "enable_drift_checks": {
      "broken_internal_links": true,
      "broken_mcp_links": true,
      "orphans": true,
      "staleness": false
    }
  },
  "ci": {
    "enabled": true
  }
}
